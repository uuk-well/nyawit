# Secret untuk enkripsi session Better Auth (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=
# URL aplikasi (wajib di production, mis. https://nyawit.vercel.app)
BETTER_AUTH_URL=http://localhost:3000
# URL publik yang dipakai client auth
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Database libSQL.
# Lokal: file:nyawit.db
# Turso (production): libsql://<db>.turso.io dan isi DATABASE_AUTH_TOKEN
DATABASE_PATH=file:nyawit.db
DATABASE_AUTH_TOKEN=
